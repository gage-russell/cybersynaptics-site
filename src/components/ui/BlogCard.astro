---
interface Props {
  title: string;
  pubDate: Date;
  description: string;
  slug: string;
}

const { title, pubDate, description, slug } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`${import.meta.env.BASE_URL}blog/${slug}`} class="blog-card">
  <time class="blog-card__date" datetime={pubDate.toISOString()}>{formattedDate}</time>
  <h3 class="blog-card__title">{title}</h3>
  <p class="blog-card__desc">{description}</p>
  <span class="blog-card__cta">Read post →</span>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-8);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .blog-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    opacity: 1;
  }

  .blog-card__date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .blog-card__title {
    color: var(--color-text);
    font-size: 1.125rem;
    line-height: 1.3;
  }

  .blog-card__desc {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: none;
  }

  .blog-card__cta {
    color: var(--color-accent-alt);
    font-weight: 600;
    font-size: 0.8125rem;
    margin-top: auto;
  }
</style>
