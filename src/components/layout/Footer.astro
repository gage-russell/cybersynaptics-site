---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const footerLinks = [
  { href: `${base}/services`, label: 'Services' },
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/blog`, label: 'Blog' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__logo">
        cybersynaptics<span class="footer__tld">.ai</span>
      </span>
      <p class="footer__tagline">Technical leadership on demand.</p>
    </div>

    <nav class="footer__nav" aria-label="Footer navigation">
      <ul class="footer__nav-list">
        {footerLinks.map(({ href, label }) => (
          <li><a href={href} class="footer__nav-link">{label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="footer__social">
      <!-- TODO: replace with real LinkedIn URL -->
      <a
        href="https://www.linkedin.com/company/cybersynaptics-ai"
        class="footer__social-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Cybersynaptics on LinkedIn"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p class="footer__copy">
        &copy; {year} Cybersynaptics.ai. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-12);
    align-items: start;
    padding-block: var(--space-12);
  }

  .footer__logo {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .footer__tld {
    color: var(--color-accent-alt);
  }

  .footer__tagline {
    margin-top: var(--space-2);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    max-width: none;
  }

  .footer__nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__nav-link {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer__nav-link:hover {
    color: var(--color-text);
    opacity: 1;
  }

  .footer__social {
    display: flex;
    gap: var(--space-3);
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition: all 0.2s;
  }

  .footer__social-link:hover {
    border-color: var(--color-accent-alt);
    color: var(--color-accent-alt);
    opacity: 1;
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-4);
  }

  .footer__copy {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    max-width: none;
  }

  @media (max-width: 767px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
