---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout
  title="Virtual CTO | Cybersynaptics.ai"
  description="Fractional CTO services for startups and growth-stage companies. Strategic technical leadership, architecture ownership, and team building — without the full-time cost."
>
  <!-- Hero -->
  <section class="service-hero section">
    <div class="container">
      <p class="eyebrow">🎯 Virtual CTO</p>
      <h1>Senior technical leadership,<br /><span class="gradient-text">on your terms.</span></h1>
      <p class="intro">
        You don't need a $300k/year CTO to get world-class technical leadership.
        AI is compressing what teams can ship while simultaneously raising the
        stakes on every architectural decision. Navigating that requires someone
        who's seen the landscape shift before. Cybersynaptics embeds a seasoned
        CTO into your organization — driving AI strategy, roadmap, architecture,
        hiring, and team culture at the pace your business demands.
      </p>
      <!-- TODO: update CTA to link to /contact once the contact page is built -->
      <Button href="https://www.linkedin.com/company/cybersynaptics-ai" variant="primary">
        Let's Talk →
      </Button>
    </div>
  </section>

  <!-- What you get -->
  <section class="section--sm">
    <div class="container content-grid">
      <div>
        <h2>What you get</h2>
        <ul class="feature-list">
          <li>Technical roadmap ownership and prioritization</li>
          <li>AI/ML strategy, tooling evaluation, and integration planning</li>
          <li>Architecture reviews and decision-making</li>
          <li>Engineering team leadership and mentorship</li>
          <li>Vendor and technology evaluation</li>
          <li>Investor and board-level technical communication</li>
          <li>Hiring bar definition and interview process design</li>
          <li>Technical due diligence support</li>
        </ul>
      </div>

      <div>
        <h2>Who it's for</h2>
        <ul class="feature-list">
          <li>Series Seed / A startups without a technical co-founder</li>
          <li>Growth-stage companies between CTO hires</li>
          <li>Founders who need a technical partner, not just a developer</li>
          <li>Organizations scaling an engineering org for the first time</li>
          <li>Companies evaluating or actively integrating AI into their product</li>
        </ul>

        <h2 style="margin-top: var(--space-8)">How it works</h2>
        <p>
          Engagements are flexible — from a weekly strategic retainer to
          embedded part-time involvement. We start with a discovery call to
          understand your stack, team, and goals, then define an engagement
          model that fits.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-block">
    <div class="container">
      <div class="cta-card">
        <h2>Ready to talk?</h2>
        <p>Tell us where you are and what's blocking you.</p>
        <!-- TODO: update CTA to link to /contact once the contact page is built -->
        <Button href="https://www.linkedin.com/company/cybersynaptics-ai" variant="primary">
          Get in Touch →
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .service-hero { padding-bottom: var(--space-16); }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-accent-alt);
    letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
    max-width: none;
  }

  h1 { margin-bottom: var(--space-6); }

  .intro {
    font-size: 1.0625rem;
    max-width: 55ch;
    margin-bottom: var(--space-8);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .feature-list {
    margin-top: var(--space-4);
    margin-bottom: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    color: var(--color-text-muted);
  }

  .feature-list li::marker {
    color: var(--color-accent-alt);
  }

  .cta-block {
    background: linear-gradient(135deg, rgba(110, 64, 201, 0.08), rgba(0, 212, 255, 0.04));
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cta-card {
    max-width: 500px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (max-width: 767px) {
    .content-grid { grid-template-columns: 1fr; }
  }
</style>
