---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ui/ServiceCard.astro';

const services = [
  {
    title: 'Virtual CTO',
    description:
      'Strategic technical leadership embedded in your organization. AI/ML strategy, roadmap ownership, architecture decisions, and team leadership — without the full-time overhead.',
    href: '/services/virtual-cto',
    icon: '🎯',
  },
  {
    title: 'Virtual CISO',
    description:
      'Security leadership built for real compliance challenges — and the AI-era threats your frameworks weren\'t written to address. SOC 2, ISO 27001, HIPAA — we keep you ahead of all of it.',
    href: '/services/virtual-ciso',
    icon: '🛡️',
  },
  {
    title: 'Software Development',
    description:
      'Senior engineers who integrate with your team and ship. AI feature development, platform engineering, project rescue — with the quality bar of an elite in-house team.',
    href: '/services/software-development',
    icon: '🚀',
  },
];
---

<BaseLayout
  title="Services | Cybersynaptics.ai"
  description="Explore Cybersynaptics services: Virtual CTO, Virtual CISO, and elite software development consulting for growing companies."
>
  <section class="section section--sm">
    <div class="container">
      <p class="eyebrow">What we offer</p>
      <h1>Our Services</h1>
      <p class="intro">
        We embed senior technical leadership into your organization — so you
        can navigate an AI-accelerated landscape on the terms that fit your
        stage, budget, and goals.
      </p>

      <div class="services-grid">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent-alt);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  h1 {
    margin-bottom: var(--space-4);
  }

  .intro {
    font-size: 1.125rem;
    max-width: 55ch;
    margin-bottom: var(--space-12);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }
</style>
