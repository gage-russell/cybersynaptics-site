---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import ServiceCard from '../components/ui/ServiceCard.astro';

const services = [
  {
    title: 'Virtual CTO',
    description:
      'Strategic technical leadership embedded in your organization. AI/ML strategy, roadmap ownership, architecture decisions, and team leadership — without the full-time overhead.',
    href: '/services/virtual-cto',
    icon: '🎯',
  },
  {
    title: 'Virtual CISO',
    description:
      'Security leadership built for real compliance challenges — and the AI-era threats your frameworks weren\'t written to address. SOC 2, ISO 27001, HIPAA — we keep you ahead of all of it.',
    href: '/services/virtual-ciso',
    icon: '🛡️',
  },
  {
    title: 'Software Development',
    description:
      'Senior engineers who integrate with your team and ship. AI feature development, Kubernetes platform engineering, cloud migrations, project rescue — with the quality bar of an elite in-house team.',
    href: '/services/software-development',
    icon: '🚀',
  },
];
---

<BaseLayout
  title="Cybersynaptics.ai | Virtual CTO, CISO & Software Consulting"
  description="Cybersynaptics embeds senior technical leadership into your organization — Virtual CTO, Virtual CISO, and elite software development — without the full-time overhead."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="hero__eyebrow">Technical leadership for an AI-accelerated world</p>
      <h1 class="hero__headline">
        The technical leaders<br />
        your company needs<br />
        <span class="gradient-text">right now.</span>
      </h1>
      <p class="hero__sub">
        As AI reshapes what software can do and what threats look like, the gap
        between companies with strong technical leadership and those without has
        never been wider. Cybersynaptics embeds senior CTOs, CISOs, and
        engineers directly into your organization — so you can build right,
        move fast, and navigate the shift with confidence.
      </p>
      <div class="hero__actions">
        <Button href="/services" variant="primary">View Services</Button>
        <Button href="/about" variant="secondary">About Us</Button>
      </div>
    </div>
    <div class="hero__grid-bg" aria-hidden="true"></div>
  </section>

  <!-- Services overview -->
  <section class="section services-overview">
    <div class="container">
      <h2 class="section-label">What we do</h2>
      <div class="services-grid">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="section cta-block">
    <div class="container">
      <div class="cta-card">
        <h2>Ready to move faster?</h2>
        <p>
          Whether you need a technical co-pilot, security guidance, or an
          engineering team that ships — let's talk.
        </p>
        <!-- TODO: update CTA to link to /contact once the contact page is built -->
        <Button
          href="https://www.linkedin.com/company/cybersynaptics-ai"
          variant="primary"
        >
          Get in Touch →
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding-block: var(--space-24);
    overflow: hidden;
  }

  .hero__grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
    z-index: -1;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 40%, transparent 100%);
  }

  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent-alt);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .hero__headline {
    margin-bottom: var(--space-6);
    max-width: 15ch;
  }

  .hero__sub {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    max-width: 50ch;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Services section */
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent-alt);
    margin-bottom: var(--space-8);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  /* CTA block */
  .cta-block {
    background: linear-gradient(135deg, rgba(110, 64, 201, 0.08), rgba(0, 212, 255, 0.04));
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .cta-card {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cta-card p {
    font-size: 1.0625rem;
  }
</style>
